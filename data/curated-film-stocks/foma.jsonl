{"brand":"Foma","name":"Retropan 320 Soft","iso":320,"filmType":"bw-negative","process":"bw","formats":["135","120","sheet"],"base":"triacetate","spectralSensitivity":"panchromatic","datasheetUrl":"https://www.foma.cz/en/retropan320","notes":"Retropan 320 soft. Special negative film with wide range of half tones and soft light. Wide latitude EI 160-1250. Recommended developer: Retro Special Developer. 135 base is gray/gray-blue cellulose triacetate; 120 and sheet use clear polyester base with antihalo backing. Sheet film offered in various sizes (box of 50). Datasheet gives no numeric resolving power or RMS granularity value.","image":"https://www.foma.cz/ew/ew_images/image?EwImage=a6e68b52-d851-432e-9aca-9ae8cd196ca5&Filter=77c1217a-447d-4780-83bd-af3cc79a9487","productUrl":"https://www.foma.cz/en/catalogue-retropan-320-soft-detail-1767","documents":[{"kind":"product-page","asset":{"url":"https://www.foma.cz/en/retropan320","title":"Foma Retropan 320 Soft technical data","source":"FOMA BOHEMIA spol. s r.o."},"publisher":"FOMA BOHEMIA spol. s r.o."}],"specSources":[{"document":{"kind":"product-page","asset":{"url":"https://www.foma.cz/en/retropan320","title":"Foma Retropan 320 Soft technical data","source":"FOMA BOHEMIA spol. s r.o."},"publisher":"FOMA BOHEMIA spol. s r.o."},"fields":["brand","name","iso","filmType","process","formats","base","spectralSensitivity","variants"],"method":"manual-transcription"}],"variants":[{"format":"135","base":"triacetate"},{"format":"120","base":"polyester"}]}
