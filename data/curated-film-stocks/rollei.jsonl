{"brand":"Rollei","name":"RPX 25","iso":25,"filmType":"bw-negative","process":"bw","formats":["135","120","4x5"],"base":"polyester","spectralSensitivity":"panchromatic","grainRms":8,"datasheetUrl":"https://www.rolleianalog.com/wp-content/uploads/2021/07/RPX25_Data-Sheet_EN_R210701.pdf","notes":"Low-sensitivity panchromatic B&W film, ISO 25/15deg. Crystal-clear 100 micron polyester base. Layer thickness 5 micron, high silver content. Resolving power 260 lp/mm at 1000:1 contrast, RMS granularity 8 (x1000). Exposure latitude +/-1 f-stop. Suitable for B&W reversal.","image":"https://www.rollei.de/cdn/shop/files/83000_RPX25_135-36_01.png?v=1718891917&width=2000","productUrl":"https://www.rolleianalog.com/produkte/rollei-rpx-25/","documents":[{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/RPX25_Data-Sheet_EN_R210701.pdf","title":"Rollei RPX 25 technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"}],"specSources":[{"document":{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/RPX25_Data-Sheet_EN_R210701.pdf","title":"Rollei RPX 25 technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"},"fields":["brand","name","iso","filmType","process","formats","base","spectralSensitivity","grainRms","resolvingPowerTests","granularityMeasurements"],"method":"manual-transcription"}],"resolvingPowerTests":[{"linesPerMm":260,"contrastRatio":"1000:1"}],"granularityMeasurements":[{"value":8,"scale":1,"kind":"rms","method":"x1000"}]}
