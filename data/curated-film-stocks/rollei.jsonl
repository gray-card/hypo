{"brand":"Rollei","name":"Retro 80S","iso":80,"filmType":"bw-negative","process":"bw","formats":["135","120"],"base":"polyester","spectralSensitivity":"superpanchromatic","grainRms":14,"datasheetUrl":"https://www.rolleianalog.com/wp-content/uploads/2021/07/Retro80S_Data-Sheet_EN_R210701.pdf","notes":"Superpanchromatic B&W film, ISO 80/20deg with extended red range up to 750 nm. Crystal-clear transparent PET base (usable as B&W slide film). Layer thickness 10 micron. Resolving power 180 lp/mm at 1000:1 contrast, RMS granularity 14 (x1000). Lower blue sensitivity. Extremely suitable for B&W reversal.","image":"https://www.rollei.de/cdn/shop/files/83004_Retro_80S_135_36_01_768a85d0-e745-490c-b356-1e43e7fd5dea.png","productUrl":"https://www.rolleianalog.com/produkte/rollei-retro-80s/","documents":[{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/Retro80S_Data-Sheet_EN_R210701.pdf","title":"Rollei Retro 80S technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"}],"specSources":[{"document":{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/Retro80S_Data-Sheet_EN_R210701.pdf","title":"Rollei Retro 80S technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"},"fields":["brand","name","iso","filmType","process","formats","base","spectralSensitivity","grainRms","resolvingPowerTests","granularityMeasurements","spectralRangeMaxNm"],"method":"manual-transcription"}],"resolvingPowerTests":[{"linesPerMm":180,"contrastRatio":"1000:1"}],"granularityMeasurements":[{"value":14,"scale":1,"kind":"rms","method":"x1000"}],"spectralRangeMaxNm":750}
{"brand":"Rollei","name":"Retro 400S","iso":400,"filmType":"bw-negative","process":"bw","formats":["135","120"],"base":"polyester","spectralSensitivity":"superpanchromatic","grainRms":11,"datasheetUrl":"https://www.rolleianalog.com/wp-content/uploads/2021/07/Retro400S_Data-Sheet_EN_R210701.pdf","notes":"Highly sensitive panchromatic B&W negative film, ISO 400/27deg, spectral sensitivity 380-730 nm (extended red). Crystal-clear transparent PET base (usable as B&W slide film). Coating thickness 10 micron. Resolving power 160 lp/mm at 1000:1 contrast, RMS granularity 11 (x1000). Exposure latitude +/-2 f-stops, pushable to ISO 800/30deg. Very suitable for B&W reversal.","image":"https://www.rollei.de/cdn/shop/files/83005_Retro_400S_135-36_01_a8d7d02d-a4df-4281-80a6-81a64350c9d5.png","productUrl":"https://www.rolleianalog.com/produkte/rollei-retro-400s/","documents":[{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/Retro400S_Data-Sheet_EN_R210701.pdf","title":"Rollei Retro 400S technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"}],"specSources":[{"document":{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/Retro400S_Data-Sheet_EN_R210701.pdf","title":"Rollei Retro 400S technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"},"fields":["brand","name","iso","filmType","process","formats","base","spectralSensitivity","grainRms","resolvingPowerTests","granularityMeasurements","spectralRangeMinNm","spectralRangeMaxNm"],"method":"manual-transcription"}],"resolvingPowerTests":[{"linesPerMm":160,"contrastRatio":"1000:1"}],"granularityMeasurements":[{"value":11,"scale":1,"kind":"rms","method":"x1000"}],"spectralRangeMinNm":380,"spectralRangeMaxNm":730}
{"brand":"Rollei","name":"Superpan 200","iso":200,"filmType":"bw-negative","process":"bw","formats":["135","120"],"base":"polyester","spectralSensitivity":"superpanchromatic","grainRms":14,"datasheetUrl":"https://www.rolleianalog.com/wp-content/uploads/2021/07/SUPERPAN200_Data-Sheet_EN_R210701.pdf","notes":"High-sensitivity superpanchromatic B&W negative film, ISO 200/24deg +/-1 f-stop, pushable to ISO 400/27deg. Extended infrared range up to 750 nm (usable as IR film with IR filter). PET base 100 micron (usable as B&W slide film). Layer thickness 10 micron. Resolving power 180 lp/mm, RMS grain size 14 (x1000). Wide exposure latitude (125-250 ISO). Extremely suitable for B&W reversal.","image":"https://www.rolleianalog.com/wp-content/uploads/2019/07/superpan200.png","productUrl":"https://www.rolleianalog.com/produkte/rollei-superpan-200/","documents":[{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/SUPERPAN200_Data-Sheet_EN_R210701.pdf","title":"Rollei Superpan 200 technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"}],"specSources":[{"document":{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/SUPERPAN200_Data-Sheet_EN_R210701.pdf","title":"Rollei Superpan 200 technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"},"fields":["brand","name","iso","filmType","process","formats","base","spectralSensitivity","grainRms","resolvingPowerTests","granularityMeasurements","spectralRangeMaxNm"],"method":"manual-transcription"}],"granularityMeasurements":[{"value":14,"scale":1,"kind":"rms","method":"x1000"}],"spectralRangeMaxNm":750,"resolvingPowerTests":[{"linesPerMm":180,"contrastRatio":"1000:1"}]}
{"brand":"Rollei","name":"Infrared 400","iso":400,"filmType":"bw-negative","process":"bw","formats":["135","120","4x5"],"base":"polyester","spectralSensitivity":"hyperpanchromatic","grainRms":11,"datasheetUrl":"https://www.rolleianalog.com/wp-content/uploads/2025/06/230821_INFRARED_Datenblatt_EN_2025.pdf","notes":"Hyperpanchromatically sensitised B&W film, nominal sensitivity ISO 200/24deg to 400/27deg, IR range 650-750 nm (IR filter recommended 715-730 nm). 7.5 micron thin, silver-rich emulsion on crystal-clear 100 micron polyester (PET) base (usable as B&W slide film). Resolving power 160 lp/mm at 1000:1 contrast, RMS granularity 11 (x1000). Very high exposure latitude. Perfect for the wood effect. Very suitable for B&W reversal.","image":"https://www.rolleianalog.com/wp-content/uploads/2019/07/infrared.png","productUrl":"https://www.rolleianalog.com/produkte/rollei-infrared/","documents":[{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2025/06/230821_INFRARED_Datenblatt_EN_2025.pdf","title":"Rollei Infrared 400 technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"}],"specSources":[{"document":{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2025/06/230821_INFRARED_Datenblatt_EN_2025.pdf","title":"Rollei Infrared 400 technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"},"fields":["brand","name","iso","filmType","process","formats","base","spectralSensitivity","grainRms","resolvingPowerTests","granularityMeasurements","spectralRangeMinNm","spectralRangeMaxNm"],"method":"manual-transcription"}],"resolvingPowerTests":[{"linesPerMm":160,"contrastRatio":"1000:1"}],"granularityMeasurements":[{"value":11,"scale":1,"kind":"rms","method":"x1000"}],"spectralRangeMinNm":650,"spectralRangeMaxNm":750}
{"brand":"Rollei","name":"Ortho 25 Plus","iso":25,"filmType":"bw-negative","process":"bw","formats":["135","120","4x5","5x7","8x10"],"base":"polyester","spectralSensitivity":"orthochromatic","grainRms":null,"resolvingPower":null,"datasheetUrl":"https://www.rolleianalog.com/wp-content/uploads/2021/07/Ortho25_Data-Sheet_EN_R210701.pdf","notes":"Low-sensitivity orthochromatic B&W film, ISO 25/15deg, blue-green sensitivity (handleable under red darkroom safelight). Polyester (PET) base, sheet film coated on 0.180 mm / 7 mil polyester (usable as B&W slide film). Very fine grain, very high sharpness. Exposure latitude up to +/-2 f-stops (development dependent). Technical/document emulsion for reproductions, astrophotography, halftone. Extremely suitable for B&W reversal.","image":"https://www.rollei.de/cdn/shop/files/83007_Ortho_25_plus_135_36_01.png?v=1718781651&width=2000","productUrl":"https://www.rolleianalog.com/produkte/rollei-ortho-25-plus/","documents":[{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/Ortho25_Data-Sheet_EN_R210701.pdf","title":"Rollei Ortho 25 Plus technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"}],"specSources":[{"document":{"kind":"technical-data","asset":{"url":"https://www.rolleianalog.com/wp-content/uploads/2021/07/Ortho25_Data-Sheet_EN_R210701.pdf","title":"Rollei Ortho 25 Plus technical data","source":"Maco Photo Products"},"publisher":"Maco Photo Products"},"fields":["brand","name","iso","filmType","process","formats","base","spectralSensitivity"],"method":"manual-transcription"}]}
