{
  "lexicon": 1,
  "id": "app.graycard.process.printSession",
  "defs": {
    "filtration": {
      "type": "object",
      "description": "Dichroic / colour-head filtration for RA-4 or variable-contrast printing. CMY values are head units as printed on the enlarger; magentaGrade is the multigrade contrast grade when using a B&W VC head.",
      "properties": {
        "cyan": { "type": "integer" },
        "magenta": { "type": "integer" },
        "yellow": { "type": "integer" },
        "note": { "type": "string", "maxLength": 128 }
      }
    },
    "wetProcess": {
      "type": "object",
      "description": "Paper processing chain for a chemically-developed print (silver-gelatin, RA-4).",
      "properties": {
        "developer": { "type": "string", "format": "at-uri", "description": "app.graycard.instance.chemistry paper developer." },
        "developerName": { "type": "string", "maxLength": 128, "description": "Free-text developer when not a tracked instance." },
        "dilution": { "type": "string", "maxLength": 64 },
        "timeSeconds": { "type": "integer", "minimum": 0 },
        "temperature": { "type": "ref", "ref": "app.graycard.defs#measure" },
        "stopBath": { "type": "string", "maxLength": 128 },
        "fixer": { "type": "string", "maxLength": 128 },
        "washTimeSeconds": { "type": "integer", "minimum": 0 },
        "agitation": { "type": "string", "maxLength": 256 }
      }
    },
    "altProcess": {
      "type": "object",
      "description": "Hand-coated / UV-exposed alternative process parameters (cyanotype, pt/pd, salt, van dyke, gum, carbon, …).",
      "properties": {
        "sensitizer": { "type": "string", "format": "at-uri", "description": "app.graycard.instance.chemistry sensitizer/coating solution." },
        "sensitizerName": { "type": "string", "maxLength": 128 },
        "coats": { "type": "integer", "minimum": 1, "description": "Number of sensitizer coats / printing layers (gum bichromate is multi-layer)." },
        "exposureUnits": { "type": "integer", "minimum": 0, "description": "Integrator units when exposure is measured in units rather than seconds (light source is the top-level `lightSource` ref)." },
        "humidityPct": { "type": "integer", "description": "Ambient/paper humidity in percent (matters for pt/pd)." },
        "negativeType": { "type": "string", "knownValues": ["in-camera", "digital-negative", "internegative", "enlarged-negative", "other"] },
        "developerName": { "type": "string", "maxLength": 128, "description": "Developing agent/bath (e.g. potassium oxalate, water)." }
      }
    },
    "digital": {
      "type": "object",
      "description": "Inkjet / digital-lab (Lightjet, Chromira) printing parameters.",
      "properties": {
        "inkSet": { "type": "string", "maxLength": 128, "description": "e.g. 'UltraChrome PRO10', 'Piezography Carbon'." },
        "iccProfile": { "type": "string", "maxLength": 256 },
        "renderingIntent": { "type": "string", "knownValues": ["perceptual", "relative-colorimetric", "saturation", "absolute-colorimetric"] },
        "resolution": { "type": "ref", "ref": "app.graycard.defs#measure", "description": "Print resolution (unit: dpi)." },
        "software": { "type": "string", "maxLength": 128, "description": "Driver / RIP (e.g. 'Print Tool', 'ImagePrint')." },
        "colorManaged": { "type": "boolean" }
      }
    },
    "toningStep": {
      "type": "object",
      "description": "One toning bath (prints may be split-toned in sequence).",
      "required": ["chemistry"],
      "properties": {
        "chemistry": { "type": "string", "format": "at-uri", "description": "app.graycard.instance.chemistry toner." },
        "name": { "type": "string", "maxLength": 128 },
        "dilution": { "type": "string", "maxLength": 64 },
        "timeSeconds": { "type": "integer", "minimum": 0 },
        "temperature": { "type": "ref", "ref": "app.graycard.defs#measure" }
      }
    },
    "main": {
      "type": "record",
      "description": "One print made in the darkroom or on a printer. Covers silver-gelatin and RA-4 enlarging/contact printing, hand-coated alternative processes, and inkjet / digital-lab output. Workflow-specific detail lives in the enlargement/wetProcess/altProcess/digital sub-objects; fill only what applies.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["createdAt"],
        "properties": {
          "printProcess": {
            "type": "string",
            "knownValues": ["silver-gelatin", "ra4", "cyanotype", "platinum-palladium", "kallitype", "salt", "van-dyke", "carbon", "gum-bichromate", "bromoil", "albumen", "wet-plate-collodion", "dye-transfer", "dye-destruction", "photogravure", "lith", "inkjet", "dye-sublimation", "other"]
          },
          "printMethod": {
            "type": "string",
            "description": "How the image reached the paper.",
            "knownValues": ["enlargement", "contact", "digital-inkjet", "digital-lab", "photogram", "other"]
          },

          "subject": { "type": "string", "format": "at-uri", "description": "What was printed — a photo (social.grain.photo) or scene subject." },
          "filmRoll": { "type": "string", "format": "at-uri", "description": "Source roll (analog), when printing from a negative." },
          "frameNumber": { "type": "integer", "minimum": 0, "description": "Source frame on the roll." },
          "sourcePhoto": { "type": "string", "format": "at-uri", "description": "Digital source file/photo for inkjet or digital-lab prints." },

          "paper": { "type": "string", "format": "at-uri", "description": "app.graycard.catalog.paperType used." },
          "paperInstance": { "type": "string", "maxLength": 128, "description": "Free-text paper batch/box when not a tracked type." },
          "size": { "type": "string", "maxLength": 64, "description": "Print/paper size, e.g. '8x10 in', '16x20 in', '30x40 cm'." },
          "widthMm": { "type": "integer", "minimum": 0 },
          "heightMm": { "type": "integer", "minimum": 0 },
          "copies": { "type": "integer", "minimum": 1 },
          "edition": { "type": "string", "maxLength": 64, "description": "Edition/print number, e.g. '3/25'." },

          "enlarger": { "type": "string", "format": "at-uri", "description": "app.graycard.instance.enlarger used." },
          "enlargingLens": { "type": "string", "format": "at-uri", "description": "app.graycard.instance.enlargingLens used." },
          "lightSource": { "type": "string", "format": "at-uri", "description": "app.graycard.instance.lightSource (UV/contact exposure unit) — for alt-process and contact printing." },
          "printer": { "type": "string", "format": "at-uri", "description": "app.graycard.instance.printer used (inkjet / digital-lab)." },
          "aperture": { "type": "string", "maxLength": 16, "description": "Enlarging-lens aperture, e.g. 'f/8'." },
          "magnification": { "type": "string", "maxLength": 64, "description": "Enlargement ratio or column height." },
          "exposureTimeSeconds": { "type": "integer", "minimum": 0, "description": "Base exposure time (enlarger or UV)." },
          "grade": { "type": "string", "maxLength": 32, "description": "Multigrade contrast grade (e.g. '2.5')." },
          "filtration": { "type": "ref", "ref": "#filtration" },
          "testStrip": { "type": "string", "maxLength": 512, "description": "Test-strip findings." },
          "dodgeBurn": { "type": "string", "maxLength": 1000, "description": "Local dodge/burn notes." },

          "wetProcess": { "type": "ref", "ref": "#wetProcess" },
          "altProcess": { "type": "ref", "ref": "#altProcess" },
          "digital": { "type": "ref", "ref": "#digital" },

          "toner": { "type": "string", "format": "at-uri", "description": "Primary toner (app.graycard.instance.chemistry). Use `toning` for multiple/split toning." },
          "toning": { "type": "array", "items": { "type": "ref", "ref": "#toningStep" } },

          "labService": { "type": "string", "maxLength": 128, "description": "Lab name when the print was made by a lab." },
          "lab": { "type": "string", "format": "at-uri", "description": "app.graycard.instance.labAccount that made the print." },

          "provenance": { "type": "ref", "ref": "app.graycard.defs#provenance" },
          "startedAt": { "type": "string", "format": "datetime" },
          "finishedAt": { "type": "string", "format": "datetime" },
          "notes": { "type": "string", "maxLength": 2000 },
          "createdAt": { "type": "string", "format": "datetime" },
          "updatedAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
