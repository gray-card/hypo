{
  "lexicon": 1,
  "id": "app.graycard.photo.workflow",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "photo",
          "run",
          "createdAt"
        ],
        "properties": {
          "photo": {
            "type": "string",
            "format": "at-uri"
          },
          "run": {
            "type": "string",
            "format": "at-uri"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      },
      "description": "Links a photo to the workflow run that produced it."
    }
  }
}
