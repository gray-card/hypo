{
  "lexicon": 1,
  "id": "app.graycard.instance.storageLocation",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "name",
          "createdAt"
        ],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 128
          },
          "storage": {
            "type": "ref",
            "ref": "app.graycard.defs#storage"
          },
          "notes": {
            "type": "string",
            "maxLength": 2000
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      },
      "description": "A place the user stores film, prints, or gear (fridge, freezer, dry cabinet, shelf)."
    }
  }
}
